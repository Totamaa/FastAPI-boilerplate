# !! WARNING !! This is an example file. Never use these values in production.
# Copy this file to `.env` and replace ALL sensitive values with your own.
# NEVER commit the `.env` file (check your .gitignore).
#
# ── How to use ───────────────────────────────────────────────────────────────
#  Dev  : `make dev`
#         → app runs locally, DB + Redis via docker-compose.yml
#  Prod : `docker compose -f docker-compose.prod.yml up -d`
#         → all services in Docker, DB is cloud-managed (no postgres container)
#         → DB_HOST points to your managed PostgreSQL (RDS, Cloud SQL, Supabase…)

# ── Prod / Deploy ─────────────────────────────────────────────────────────────
DOCKER_IMAGE=ghcr.io/yourorg/moviedb:latest  # image built by CI and pushed to registry
CADDY_DOMAIN=api.example.com                  # domain pointing to this VPS (for TLS)

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=dev                          # test | dev | ppr | prod
APP_NAME=FastAPI Boilerplate
APP_VERSION=0.1.0
APP_DESCRIPTION=Movie database backend API
APP_PORT=8000                            # internal port used by uvicorn (Caddy proxies to it)
APP_WORKERS=1                            # uvicorn workers — set to nb of vCPUs in prod

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]   # list of allowed origins

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG                          # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_MAX_BYTES=10485760                   # 10 MB
LOG_BACKUP_COUNT=5

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=moviedb
DB_USER=moviedb_user
DB_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
# !! openssl rand -hex 64

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
# !! openssl rand -hex 64

# ── API Key ──────────────────────────────────────────────────────────────────
API_KEY=REPLACE_WITH_A_RANDOM_HEX_64_BYTES
# !! openssl rand -hex 64

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256                      # HS256 | RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30       # max 60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7          # max 45
JWT_SESSION_MAX_LIFETIME_DAYS=30         # max 100
JWT_SESSION_MAX_COUNT=5                  # max 10
JWT_SECRET_KEY=REPLACE_WITH_A_SECRET_KEY_OF_AT_LEAST_64_CHARS
# !! openssl rand -hex 64

# ── Cache ────────────────────────────────────────────────────────────────────
CACHE_MAX_AGE_SHORT=60                   # seconds — list endpoints (movies, actors, …)
CACHE_MAX_AGE_LONG=300                   # seconds — detail endpoints (movie/{id}, …)

# ── Scheduler ────────────────────────────────────────────────────────────────
# refresh_movie_stats  → runs daily at 02:00 UTC (batch recalculates avg_rating / review_count)
# log_trending_movies  → runs every Monday at 08:00 UTC (top-10 most-reviewed movies last 7 days)
